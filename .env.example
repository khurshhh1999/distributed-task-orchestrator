# Local development environment variables
# Copy to .env and adjust as needed

DATABASE_URL=jdbc:postgresql://localhost:5432/task_orchestrator
DATABASE_USERNAME=orchestrator
DATABASE_PASSWORD=orchestrator

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=task-worker-group

# Retry sweeper (task-worker durability safety net)
RETRY_SWEEPER_INTERVAL_MS=15000
RETRY_SWEEPER_INITIAL_DELAY_MS=20000
RETRY_SWEEPER_STALE_THRESHOLD_MS=30000
RETRY_SWEEPER_BATCH_SIZE=100

SERVER_PORT=8080
